<div style="height: 3rem;"></div>

<section class="login-section">
    <h2>Login</h2>

    <div class="error-message" style="color: red;"></div>

    <form id="loginForm">
        <div class="login-form-group">
            <label for="dlsuEmail">DLSU Email</label>
            <input type="email" id="dlsuEmail" name="dlsuEmail" placeholder="username@dlsu.edu.ph" required>
        </div>

        <div class="login-form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" placeholder="Enter your password" required>
        </div>

        <button type="submit" class="login-btn-primary" style="margin-bottom: 15px;">Login</button>

        <a href="/forgot-password" 
           style="display: block; width: 100%; text-align: center; padding: 12px; background-color: #f8f9fa; color: #333; border: 1px solid #ccc; border-radius: 4px; text-decoration: none; font-weight: bold; font-size: 1.1em; box-sizing: border-box; cursor: pointer;">
            Forgot Password?
        </a>
    </form>

    <p class="login-sign-up-link" style="text-align: center; margin-top: 25px; font-size: 1.1em;">
        Don't have an account? <a href="/register" style="font-weight: bold; color: #007bff;">Sign Up</a>
    </p>
</section>