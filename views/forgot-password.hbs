<div style="height: 3rem;"></div>
<section class="register-section" style="max-width: 500px; margin: auto;">
    <h2>Recover Account</h2>
    <p style="text-align: center; color: #555; margin-bottom: 20px;">
        Enter your DLSU email and the answer to your security question to reset your password.
    </p>
    
    <div id="reset-message" style="margin-bottom: 15px; padding: 10px; border-radius: 4px; font-weight: bold; display: none;"></div>

    <form id="forgotPasswordForm">
        <div class="form-group">
            <label for="dlsuEmail">DLSU Email</label>
            <input type="email" id="dlsuEmail" name="dlsuEmail" placeholder="username@dlsu.edu.ph" required>
        </div>

        <div class="form-group">
            <label for="securityAnswer">Security Answer</label>
            <input type="text" id="securityAnswer" name="securityAnswer" placeholder="Enter your specific answer" required>
        </div>

        <div class="form-group">
            <label for="newPassword">New Password</label>
            <input type="password" id="newPassword" name="newPassword" placeholder="Create a new password" required>
            <small style="display: block; color: #666; margin-top: 5px; font-size: 0.85em;">
                Must be 8-64 characters with at least 1 uppercase, 1 lowercase, 1 number, and 1 special character.
            </small>
        </div>

        <div class="form-group">
            <label for="confirmPassword">Confirm New Password</label>
            <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm your new password" required>
        </div>

        <button type="submit" class="btn-primary" style="margin-top: 15px; width: 100%;">Reset Password</button>
    </form>

    <p class="sign-in-link" style="text-align: center; margin-top: 20px;">
        Remembered your password? <a href="/login">Sign In</a>
    </p>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const forgotPasswordForm = document.getElementById('forgotPasswordForm');
    const messageBox = document.getElementById('reset-message');

    if (forgotPasswordForm) {
        forgotPasswordForm.addEventListener('submit', async (e) => {
            e.preventDefault(); 
            
            const dlsuEmail = document.getElementById('dlsuEmail').value.trim();
            const securityAnswer = document.getElementById('securityAnswer').value.trim();
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;

            // Frontend Validation: Check if passwords match
            if (newPassword !== confirmPassword) {
                messageBox.style.display = 'block';
                messageBox.style.backgroundColor = '#f2dede';
                messageBox.style.color = '#a94442';
                messageBox.style.border = '1px solid #ebccd1';
                messageBox.textContent = 'New passwords do not match.';
                return;
            }

            // Temporarily disable the button
            const submitBtn = forgotPasswordForm.querySelector('button[type="submit"]');
            submitBtn.disabled = true;
            submitBtn.textContent = 'Verifying...';

            try {
                // Send JSON payload to the backend controller
                const response = await fetch('/api/auth/reset-password', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ 
                        dlsuEmail, 
                        securityAnswer, 
                        newPassword 
                    })
                });
                
                const data = await response.json();
                messageBox.style.display = 'block';
                
                if (response.ok) {
                    // Success: Password was reset successfully
                    messageBox.style.backgroundColor = '#dff0d8';
                    messageBox.style.color = '#3c763d';
                    messageBox.style.border = '1px solid #d6e9c6';
                    messageBox.textContent = data.message + ' Redirecting to login...';
                    
                    forgotPasswordForm.reset();
                    
                    // Redirect to login page after a short delay
                    setTimeout(() => {
                        window.location.href = '/login';
                    }, 2000);
                } else {
                    // Backend Error: (e.g., wrong answer, complexity failed, old password re-used)
                    messageBox.style.backgroundColor = '#f2dede';
                    messageBox.style.color = '#a94442';
                    messageBox.style.border = '1px solid #ebccd1';
                    messageBox.textContent = data.message;
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Reset Password';
                }
            } catch (error) {
                console.error('Password reset error:', error);
                messageBox.style.display = 'block';
                messageBox.style.backgroundColor = '#f2dede';
                messageBox.style.color = '#a94442';
                messageBox.textContent = 'An unexpected system error occurred. Please try again later.';
                submitBtn.disabled = false;
                submitBtn.textContent = 'Reset Password';
            }
        });
    }
});
</script>